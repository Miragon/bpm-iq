<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_invoice-handling" targetNamespace="http://acme-commerce.example/bpmn">
  <bpmn:process id="invoice-handling" name="Invoice Handling" isExecutable="false">
    <bpmn:startEvent id="Start_invoice_requested" name="Invoice requested">
      <bpmn:outgoing>Flow_ih_create</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_create_invoice" name="Create invoice">
      <bpmn:incoming>Flow_ih_create</bpmn:incoming>
      <bpmn:outgoing>Flow_ih_send</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_send_invoice" name="Send invoice to customer">
      <bpmn:incoming>Flow_ih_send</bpmn:incoming>
      <bpmn:outgoing>Flow_ih_await</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:receiveTask id="Task_await_payment" name="Await payment">
      <bpmn:incoming>Flow_ih_await</bpmn:incoming>
      <bpmn:incoming>Flow_ih_back</bpmn:incoming>
      <bpmn:outgoing>Flow_ih_recorded</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="Boundary_terms_expired" name="Payment terms expired" attachedToRef="Task_await_payment">
      <bpmn:outgoing>Flow_ih_remind</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_terms" />
    </bpmn:boundaryEvent>
    <bpmn:sendTask id="Task_send_reminder" name="Send payment reminder">
      <bpmn:incoming>Flow_ih_remind</bpmn:incoming>
      <bpmn:outgoing>Flow_ih_back</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_payment_recorded" name="Payment recorded">
      <bpmn:incoming>Flow_ih_recorded</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ih_create" sourceRef="Start_invoice_requested" targetRef="Task_create_invoice" />
    <bpmn:sequenceFlow id="Flow_ih_send" sourceRef="Task_create_invoice" targetRef="Task_send_invoice" />
    <bpmn:sequenceFlow id="Flow_ih_await" sourceRef="Task_send_invoice" targetRef="Task_await_payment" />
    <bpmn:sequenceFlow id="Flow_ih_recorded" sourceRef="Task_await_payment" targetRef="End_payment_recorded" />
    <bpmn:sequenceFlow id="Flow_ih_remind" sourceRef="Boundary_terms_expired" targetRef="Task_send_reminder" />
    <bpmn:sequenceFlow id="Flow_ih_back" sourceRef="Task_send_reminder" targetRef="Task_await_payment" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_invoice-handling">
    <bpmndi:BPMNPlane id="BPMNPlane_invoice-handling" bpmnElement="invoice-handling">
      <bpmndi:BPMNShape id="Start_invoice_requested_di" bpmnElement="Start_invoice_requested">
        <dc:Bounds x="152" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="126" y="205" width="88" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_create_invoice_di" bpmnElement="Task_create_invoice">
        <dc:Bounds x="240" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_send_invoice_di" bpmnElement="Task_send_invoice">
        <dc:Bounds x="390" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_await_payment_di" bpmnElement="Task_await_payment">
        <dc:Bounds x="540" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Boundary_terms_expired_di" bpmnElement="Boundary_terms_expired">
        <dc:Bounds x="572" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="612" y="228" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_send_reminder_di" bpmnElement="Task_send_reminder">
        <dc:Bounds x="540" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_payment_recorded_di" bpmnElement="End_payment_recorded">
        <dc:Bounds x="740" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="713" y="205" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_ih_create_di" bpmnElement="Flow_ih_create">
        <di:waypoint x="188" y="180" />
        <di:waypoint x="240" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ih_send_di" bpmnElement="Flow_ih_send">
        <di:waypoint x="340" y="180" />
        <di:waypoint x="390" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ih_await_di" bpmnElement="Flow_ih_await">
        <di:waypoint x="490" y="180" />
        <di:waypoint x="540" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ih_recorded_di" bpmnElement="Flow_ih_recorded">
        <di:waypoint x="640" y="180" />
        <di:waypoint x="740" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ih_remind_di" bpmnElement="Flow_ih_remind">
        <di:waypoint x="590" y="238" />
        <di:waypoint x="590" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ih_back_di" bpmnElement="Flow_ih_back">
        <di:waypoint x="540" y="330" />
        <di:waypoint x="470" y="330" />
        <di:waypoint x="470" y="180" />
        <di:waypoint x="540" y="180" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
