<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" id="Definitions_credit-check" name="Credit check" namespace="http://acme-commerce.example/dmn">
  <decision id="credit-check" name="Credit approved?">
    <description>Implements Internal credit policy CP-7 (the preventive control on Task_check_credit). Evaluated by "Check credit limit" and applied at Gateway_credit_approved in order-to-cash.bpmn: approved = true routes to "yes" (fulfill), false to "no" (reject).</description>
    <variable id="Variable_credit-check" name="approved" typeRef="boolean" />
    <informationRequirement id="InformationRequirement_order">
      <requiredInput href="#InputData_order" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_credit_account">
      <requiredInput href="#InputData_credit_account" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_credit_limit">
      <requiredInput href="#InputData_credit_limit" />
    </informationRequirement>
    <decisionTable id="DecisionTable_credit-check" hitPolicy="FIRST">
      <input id="Input_projected_exposure" label="Projected exposure">
        <inputExpression id="InputExpression_projected_exposure" typeRef="number">
          <text>openExposure + orderAmount</text>
        </inputExpression>
      </input>
      <input id="Input_order_amount" label="Order amount">
        <inputExpression id="InputExpression_order_amount" typeRef="number">
          <text>orderAmount</text>
        </inputExpression>
      </input>
      <output id="Output_approved" label="Approved" name="approved" typeRef="boolean" />
      <rule id="Rule_within_limit">
        <description>Projected exposure stays within the credit limit (CP-7 §2).</description>
        <inputEntry id="InputEntry_within_limit_exposure">
          <text>&lt;= creditLimit</text>
        </inputEntry>
        <inputEntry id="InputEntry_within_limit_amount">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_within_limit">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="Rule_small_order_tolerance">
        <description>Small orders (&lt; 500 EUR) tolerated up to 10% over the limit (CP-7 §3).</description>
        <inputEntry id="InputEntry_small_order_exposure">
          <text>&lt;= creditLimit * 1.1</text>
        </inputEntry>
        <inputEntry id="InputEntry_small_order_amount">
          <text>&lt; 500</text>
        </inputEntry>
        <outputEntry id="OutputEntry_small_order">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="Rule_default_reject">
        <description>Default deny: order would exceed the credit limit (CP-7 §1).</description>
        <inputEntry id="InputEntry_default_reject_exposure">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_default_reject_amount">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_default_reject">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <inputData id="InputData_order" name="Order">
    <description>Provides orderAmount: the total of the incoming order in EUR.</description>
    <variable id="Variable_order" name="orderAmount" typeRef="number" />
  </inputData>
  <inputData id="InputData_credit_account" name="Open exposure">
    <description>Provides openExposure: the customer's current open exposure from the ERP (system of record for orders and invoices).</description>
    <variable id="Variable_credit_account" name="openExposure" typeRef="number" />
  </inputData>
  <inputData id="InputData_credit_limit" name="Credit limit">
    <description>Provides creditLimit: the customer's credit limit from the ERP, set during customer onboarding.</description>
    <variable id="Variable_credit_limit" name="creditLimit" typeRef="number" />
  </inputData>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_credit-check">
      <dmndi:DMNShape id="DMNShape_credit_check" dmnElementRef="credit-check">
        <dc:Bounds height="80" width="180" x="280" y="80" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="DMNShape_input_order" dmnElementRef="InputData_order">
        <dc:Bounds height="45" width="125" x="100" y="240" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="DMNShape_input_credit_account" dmnElementRef="InputData_credit_account">
        <dc:Bounds height="45" width="125" x="300" y="240" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="DMNShape_input_credit_limit" dmnElementRef="InputData_credit_limit">
        <dc:Bounds height="45" width="125" x="500" y="240" />
      </dmndi:DMNShape>
      <dmndi:DMNEdge id="DMNEdge_req_order" dmnElementRef="InformationRequirement_order">
        <di:waypoint x="162" y="240" />
        <di:waypoint x="330" y="160" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="DMNEdge_req_credit_account" dmnElementRef="InformationRequirement_credit_account">
        <di:waypoint x="362" y="240" />
        <di:waypoint x="370" y="160" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="DMNEdge_req_credit_limit" dmnElementRef="InformationRequirement_credit_limit">
        <di:waypoint x="562" y="240" />
        <di:waypoint x="410" y="160" />
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
