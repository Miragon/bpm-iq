<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Example" targetNamespace="https://bpmiq.dev/starter">
  <bpmn:process id="Process_Example" name="Example" isExecutable="false">
    <bpmn:startEvent id="StartEvent_RequestReceived" name="Request received">
      <bpmn:outgoing>Flow_ToHandle</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_HandleRequest" name="Handle request">
      <bpmn:incoming>Flow_ToHandle</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDone</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_RequestHandled" name="Request handled">
      <bpmn:incoming>Flow_ToDone</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToHandle" sourceRef="StartEvent_RequestReceived" targetRef="Task_HandleRequest" />
    <bpmn:sequenceFlow id="Flow_ToDone" sourceRef="Task_HandleRequest" targetRef="EndEvent_RequestHandled" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Example">
    <bpmndi:BPMNPlane id="BPMNPlane_Example" bpmnElement="Process_Example">
      <bpmndi:BPMNShape id="StartEvent_RequestReceived_di" bpmnElement="StartEvent_RequestReceived">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="127" y="145" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleRequest_di" bpmnElement="Task_HandleRequest">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RequestHandled_di" bpmnElement="EndEvent_RequestHandled">
        <dc:Bounds x="392" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="368" y="145" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_ToHandle_di" bpmnElement="Flow_ToHandle">
        <di:waypoint x="188" y="120" />
        <di:waypoint x="240" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToDone_di" bpmnElement="Flow_ToDone">
        <di:waypoint x="340" y="120" />
        <di:waypoint x="392" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
