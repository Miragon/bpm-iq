{
  "name": "@bpmiq/mcp",
  "version": "0.2.0",
  "description": "Read-only MCP server exposing a BPM content repo’s process dependency graph (process.yaml + landscape models) to any MCP client.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miragon/bpm-iq.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "bpm",
    "bpmn",
    "dmn",
    "mcp",
    "model-context-protocol",
    "process-documentation"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "bpmiq-mcp": "server.ts"
  },
  "exports": {
    ".": "./server.ts",
    "./http": "./http.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/server.js",
      "./http": "./dist/http.js"
    },
    "bin": {
      "bpmiq-mcp": "dist/server.js"
    }
  },
  "scripts": {
    "start": "node server.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "fast-xml-parser": "4.5.7",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@bpmiq/contracts": "workspace:*",
    "@bpmiq/notations": "workspace:*",
    "tsdown": "0.22.8"
  }
}
