{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/miragon/bpm-architecture/schemas/process.schema.json",
  "title": "Process metadata (process.yaml)",
  "description": "Schema for per-process metadata. Reference: docs/process-metadata.md. Cross-file link integrity (landscape ids, BPMN element ids, file paths) is checked by scripts/validate.ts, not by this schema.",
  "type": "object",
  "required": [
    "id",
    "name",
    "classification",
    "level",
    "version",
    "status",
    "last_reviewed",
    "purpose",
    "trigger",
    "outcome",
    "owner",
    "models"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "enum": [
        "core",
        "support",
        "management"
      ]
    },
    "level": {
      "enum": [
        2,
        3
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": [
        "draft",
        "to-be",
        "as-is",
        "deprecated"
      ]
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "review_cycle_months": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "required": [
        "team"
      ],
      "additionalProperties": false,
      "properties": {
        "team": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "team",
          "interaction"
        ],
        "additionalProperties": false,
        "properties": {
          "team": {
            "type": "string"
          },
          "interaction": {
            "enum": [
              "collaboration",
              "x-as-a-service",
              "facilitating"
            ]
          }
        }
      }
    },
    "value_chain": {
      "type": "object",
      "required": [
        "steps"
      ],
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "supports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "wardley": {
      "type": "object",
      "required": [
        "components"
      ],
      "additionalProperties": false,
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "target",
          "direction"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "direction": {
            "enum": [
              "lower-is-better",
              "higher-is-better",
              "target-band"
            ]
          },
          "source": {
            "type": "string"
          },
          "measured_from": {
            "type": "string"
          },
          "measured_to": {
            "type": "string"
          },
          "actuals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "date",
                "value"
              ],
              "additionalProperties": false,
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "volume": {
          "type": "object",
          "required": [
            "cases_per_period",
            "period",
            "as_of"
          ],
          "additionalProperties": false,
          "properties": {
            "cases_per_period": {
              "type": "number"
            },
            "period": {
              "enum": [
                "day",
                "week",
                "month",
                "quarter",
                "year"
              ]
            },
            "as_of": {
              "type": "string",
              "format": "date"
            },
            "source": {
              "type": "string"
            }
          }
        },
        "cost": {
          "type": "object",
          "required": [
            "as_of"
          ],
          "additionalProperties": false,
          "properties": {
            "per_case": {
              "type": "string"
            },
            "ftes": {
              "type": "number"
            },
            "as_of": {
              "type": "string",
              "format": "date"
            }
          }
        }
      }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "role"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "models": {
      "type": "object",
      "required": [
        "bpmn"
      ],
      "additionalProperties": false,
      "properties": {
        "bpmn": {
          "type": "string",
          "pattern": "(\\.bpmn)$"
        },
        "dmn": {
          "type": "string",
          "pattern": "(\\.dmn)$"
        },
        "wardley": {
          "type": "string",
          "pattern": "(\\.owm|\\.wmap)$"
        },
        "team-topology": {
          "type": "string",
          "pattern": "(\\.tt|\\.ttm\\.json)$"
        },
        "value-chain": {
          "type": "string",
          "pattern": "(\\.vc\\.json)$"
        }
      }
    },
    "subprocesses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "file"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "pattern": "\\.bpmn$"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "file",
          "used_by"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string"
          },
          "file": {
            "type": "string",
            "pattern": "\\.dmn$"
          },
          "used_by": {
            "type": "string"
          }
        }
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_processes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "relationship"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "relationship": {
            "enum": [
              "upstream",
              "downstream",
              "supporting",
              "escalation"
            ]
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "handling"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "handling": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "impact"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "impact": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "mitigated_by": {
            "type": "string"
          }
        }
      }
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "element"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "enum": [
              "preventive",
              "detective"
            ]
          },
          "element": {
            "type": "string"
          },
          "requirement": {
            "type": "string"
          }
        }
      }
    },
    "automation": {
      "type": "object",
      "required": [
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "candidate",
            "in-development",
            "live"
          ]
        },
        "engine": {
          "enum": [
            "camunda-7",
            "camunda-8",
            "other"
          ]
        },
        "model": {
          "type": "string",
          "pattern": "\\.bpmn$"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "mining": {
      "type": "object",
      "required": [
        "case_id"
      ],
      "additionalProperties": false,
      "properties": {
        "case_id": {
          "type": "object",
          "required": [
            "name",
            "system"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "system": {
              "type": "string"
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "activity",
              "system",
              "event"
            ],
            "additionalProperties": false,
            "properties": {
              "activity": {
                "type": "string"
              },
              "system": {
                "type": "string"
              },
              "event": {
                "type": "string"
              }
            }
          }
        },
        "no_digital_trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "required": [
        "approved_by",
        "date",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "approved_by": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "version",
          "date",
          "change"
        ],
        "additionalProperties": false,
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "change": {
            "type": "string"
          },
          "changed_by": {
            "type": "string"
          }
        }
      }
    },
    "published": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "location",
          "date"
        ],
        "additionalProperties": false,
        "properties": {
          "location": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "contact": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "classification": {
            "const": "core"
          }
        }
      },
      "then": {
        "required": [
          "value_chain"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "classification": {
            "const": "support"
          }
        }
      },
      "then": {
        "required": [
          "supports"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "as-is"
          }
        }
      },
      "then": {
        "required": [
          "approval"
        ]
      }
    }
  ]
}
