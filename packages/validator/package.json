{
  "name": "@bpmiq/validator",
  "version": "2.1.0",
  "type": "module",
  "description": "Platform-owned validator for BPM content repos — bpmiq.yml discovery + BPMN structure and BPMNDI coverage. Runs against any checkout via --root; never executes content-repo code.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miragon/bpm-iq.git",
    "directory": "packages/validator"
  },
  "keywords": [
    "bpm",
    "bpmn",
    "validator",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "bpmiq-validate": "src/validate.ts"
  },
  "exports": {
    ".": "./src/validate.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/validate.js"
    },
    "bin": {
      "bpmiq-validate": "dist/validate.js"
    }
  },
  "scripts": {
    "validate": "node src/validate.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/validate.test.ts"
  },
  "dependencies": {
    "fast-xml-parser": "5.9.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@bpmiq/notations": "workspace:*",
    "tsdown": "0.22.8"
  }
}
