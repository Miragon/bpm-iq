{
  "name": "@bpmiq/ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared shadcn (new-york) UI kit for the bpmiq SPAs — raw .tsx/.css sources consumed directly by Vite, no build step. react/react-dom are peerDependencies: pnpm auto-installs them and both SPAs pin the same range, guaranteeing a single React instance.",
  "exports": {
    "./components/*": "./src/components/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "1.2.3",
    "@radix-ui/react-dropdown-menu": "2.1.21",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
