{
  // Browser component sources (React JSX, no build — Vite consumes the raw .tsx).
  // Mirrors the SPAs' compiler surface; tsc is a pure type gate.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": []
  },
  "include": ["src"]
}
