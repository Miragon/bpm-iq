# bpmiq Live Host — environment reference (docker-compose reads this via env_file).
# Every variable the server reads (composition root: apps/live-host/src/server.ts).
# Copy to .env, uncomment what you need. Defaults shown are the code's defaults.

# ── Core ─────────────────────────────────────────────────────────────────────
# REQUIRED in production: the public origin users reach. OAuth callbacks
# (<url>/auth/github/callback), the webhook receiver (<url>/webhook/github) and
# Secure cookies all derive from it. With TLS termination (caddy) this is the
# https URL. Default: http://localhost:<PORT> — dev only.
LIVE_PUBLIC_URL=https://bpm.example.com

# PORT is pinned to 8080 IN the container by the image — do not set it here;
# map the host port in docker-compose.yml ("8301:8080") instead.
#PORT=8080

# Host-owned state (live.db, workspace clones). The image sets /data — mount a
# volume there (compose: ./data:/data) and leave this unset.
#LIVE_DATA_DIR=/data

# ── GitHub OAuth login ───────────────────────────────────────────────────────
# The login button ("Sign in with GitHub") appears only when BOTH are set —
# they come from the central GitHub App (created once via `pnpm create-app`).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub App — multi-repo mode ─────────────────────────────────────────────
# With app credentials the connected-repo set derives from the App's
# installations (repo overview, on-demand clones, app-side authorization).
GITHUB_APP_ID=
# Public app slug (not a secret) — enables app mode + the install-picker URL.
GITHUB_APP_SLUG=

# App private key — first match wins:
#   GITHUB_APP_PRIVATE_KEY       raw PEM (quote it; multi-line is fine)
#   GITHUB_APP_PRIVATE_KEY_FILE  path to a mounted .pem
#   GITHUB_APP_PRIVATE_KEY_B64   base64 one-liner — the compose-friendly variant
GITHUB_APP_PRIVATE_KEY_B64=
#GITHUB_APP_PRIVATE_KEY_FILE=/data/app.pem
#GITHUB_APP_PRIVATE_KEY=

# Verifies installation-lifecycle webhooks at POST /webhook/github (HMAC).
GITHUB_WEBHOOK_SECRET=

# Webhook URL written into the App manifest by `pnpm create-app` — defaults to
# ${LIVE_PUBLIC_URL}/webhook/github when the host is publicly reachable.
#LIVE_WEBHOOK_URL=

# Fallback single repo when NO app credentials are configured (static registry
# entry instead of installation enumeration), and its base branch.
#GITHUB_REPO=my-org/my-processes
#BASE_BRANCH=main

# ── GitHub Enterprise ────────────────────────────────────────────────────────
# Point both at your GHE instance (or at test/stub-provider.ts for offline dev).
#GITHUB_BASE_URL=https://github.com
#GITHUB_API_URL=https://api.github.com

# ── Security & limits ────────────────────────────────────────────────────────
# At-rest encryption key for stored provider tokens (and the OAuth-state HMAC
# is derived from it). Falls back to CELL_TOKEN_KEY, then GITHUB_CLIENT_SECRET —
# set it EXPLICITLY in production so key rotation is independent of the OAuth app.
SESSION_ENC_KEY=

# Per-room document size cap in bytes (DoS guard, enforced at ingest + persist).
#LIVE_MAX_DOC_BYTES=8000000
# WebSocket connection ceilings: global and per client IP.
#LIVE_MAX_WS=400
#LIVE_MAX_WS_PER_IP=40
# Shutdown hard-exit in ms — time to flush debounced write-throughs on SIGTERM.
# Must stay BELOW the container's stop grace period (compose: 30s).
#LIVE_SHUTDOWN_MS=25000

# ── Dev only — never in production ───────────────────────────────────────────
# Shared bearer token for headless clients (tests, VS Code). It BYPASSES
# per-repo authorization. Defaults to 'demo' ONLY when no login provider is
# configured AND no connection source can enumerate repos (bare local spike);
# the moment real credentials exist it is off unless set explicitly.
#LIVE_DEV_TOKEN=
# Serve local content for the fallback repo without a clone (dev checkout).
#LIVE_HOST_CONTENT_DIR=
# Offline/test escape hatches: rewrite clone/fetch and push remotes to local
# bare repos (see test/release-e2e.sh).
#LIVE_GIT_URL_OVERRIDE=
#LIVE_PUSH_URL_OVERRIDE=

# ── Cell mode — Miragon hosted operation only, leave unset on-prem ───────────
# ADR 0002: a cell serves ONE tenant, holds no App key, and gets installation
# tokens minted remotely by the control plane.
#TENANT_INSTALLATION_ID=
#TOKEN_MINT_URL=
#CELL_SECRET=
#CELL_TOKEN_KEY=
#HANDOFF_SECRET=
